.auth-container
  .auth-card
    %h2.auth-title= "Edit #{resource_name.to_s.humanize}"

    = render "devise/shared/error_messages", resource: resource

    = form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }, local: true) do |f|
      .form-group
        = f.label :email
        = f.email_field :email, autofocus: true, autocomplete: "email", class: "form-input"

      - if devise_mapping.confirmable? && resource.pending_reconfirmation?
        .pending-confirmation
          Currently waiting confirmation for: #{resource.unconfirmed_email}

      .form-group
        = f.label :password
        %em.password-hint (leave blank if you don't want to change it)
        = f.password_field :password, autocomplete: "new-password", class: "form-input"
        - if @minimum_password_length
          %em.password-hint= "#{@minimum_password_length} characters minimum"

      .form-group
        = f.label :password_confirmation
        = f.password_field :password_confirmation, autocomplete: "new-password", class: "form-input"

      .form-group
        = f.label :current_password
        %em.password-hint (we need your current password to confirm your changes)
        = f.password_field :current_password, autocomplete: "current-password", class: "form-input"

      .form-actions
        = f.submit "Update", class: "btn-primary"

    .delete-account-section
      %h3 Delete Account
      %p Unhappy? You can permanently delete your account.
      = button_to "Delete my account", registration_path(resource_name), data: { turbo_confirm: "Are you sure? This cannot be undone." }, method: :delete, class: "btn-danger"

    .back-link
      = link_to "← Back to Dashboard", root_path
