<% content_for :title, "#{@type_label} — Naked Capitalism Archive" %>

<p class="back-link"><%= link_to "← back to dashboard", root_path %></p>

<h1><%= @type_label %></h1>

<p class="meta">
  Showing posts published on or before
  <strong><%= @cutoff.strftime("%Y-%m-%d") %></strong>
  (reading lag: <%= pluralize(@lag_months, "month") %>).
  <% if @hidden_count.positive? %>
    <%= pluralize(@hidden_count, "newer post") %> hidden.
  <% end %>
  <br>
  Adjust the lag with <code>?lag=N</code> in the URL
  (e.g. <%= link_to "lag=4", posts_by_type_path(post_type: @post_type, lag: 4) %>,
  <%= link_to "lag=12", posts_by_type_path(post_type: @post_type, lag: 12) %>).
</p>

<% if @posts.empty? %>
  <div class="empty">
    <p>No <%= @type_label.downcase %> are past the <%= @lag_months %>-month lag yet.</p>
    <% if @hidden_count.positive? %>
      <p><%= pluralize(@hidden_count, "post") %> exist of this type but are still
        too recent to read. Try a shorter lag, e.g.
        <%= link_to "?lag=1", posts_by_type_path(post_type: @post_type, lag: 1) %>.</p>
    <% else %>
      <p>The archive doesn't contain any posts of this type yet — try
        <code>bin/rails 'nc_archive:backfill[12]'</code> to widen the backfill.</p>
    <% end %>
  </div>
<% else %>
  <p class="meta"><%= pluralize(@posts.size, "post") %>, oldest first.</p>
  <table>
    <thead>
      <tr><th>Date</th><th>Title</th></tr>
    </thead>
    <tbody>
      <% @posts.each do |post| %>
        <tr class="post-row <%= "is-read" if post.read? %>">
          <td class="post-date"><%= post.published_at.strftime("%Y-%m-%d") %></td>
          <td>
            <%= link_to post.title, post.url,
                target: "_blank",
                rel: "noopener",
                class: "post-link",
                data: { mark_read_url: open_post_path(post) } %>
            <% if post.read? %>
              <span class="read-marker">read <%= post.read_at.strftime("%Y-%m-%d") %></span>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <script>
    // Mark-as-read on click. The browser handles target=_blank natively, so
    // the source URL opens in a new tab regardless. We fire a fetch() in
    // parallel to record the read and update this row inline.
    (function () {
      function formatDate(iso) {
        // YYYY-MM-DD from an ISO 8601 string, in the user's local TZ.
        const d = new Date(iso);
        if (isNaN(d)) return "";
        const y  = d.getFullYear();
        const m  = String(d.getMonth() + 1).padStart(2, "0");
        const dd = String(d.getDate()).padStart(2, "0");
        return `${y}-${m}-${dd}`;
      }

      function markRowAsRead(link, readAtIso) {
        const row = link.closest("tr.post-row");
        if (!row) return;
        row.classList.add("is-read");
        const cell = link.parentNode;
        if (!cell.querySelector(".read-marker")) {
          const span = document.createElement("span");
          span.className = "read-marker";
          span.textContent = `read ${formatDate(readAtIso)}`;
          cell.appendChild(span);
        }
      }

      document.addEventListener("click", function (event) {
        const link = event.target.closest("a.post-link[data-mark-read-url]");
        if (!link) return;
        // Don't preventDefault: target=_blank handles the new tab.
        const url = link.dataset.markReadUrl;
        fetch(url, {
          method: "GET",
          headers: { "Accept": "application/json" },
          credentials: "same-origin"
        })
          .then(function (res) { return res.ok ? res.json() : null; })
          .then(function (data) {
            if (data && data.read_at) markRowAsRead(link, data.read_at);
          })
          .catch(function (err) { console.error("mark-read failed", err); });
      });
    })();
  </script>
<% end %>
