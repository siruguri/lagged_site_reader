<% content_for :title, "Naked Capitalism Archive" %>

<h1>Naked Capitalism Archive</h1>
<p class="sub">Local read-on-a-lag archive of nakedcapitalism.com posts.</p>

<% if @total.zero? %>
  <div class="empty">
    <p><strong>No posts archived yet.</strong></p>
    <p>Backfill the last 6 months:</p>
    <p><code>bin/rails 'nc_archive:backfill[6]'</code></p>
    <p>Or smoke-test the API first:</p>
    <p><code>bin/rails nc_archive:healthcheck</code></p>
  </div>
<% else %>
  <dl>
    <dt>Oldest post</dt>
    <dd><%= @oldest_published_at&.strftime("%Y-%m-%d %H:%M UTC") %></dd>

    <dt>Newest post</dt>
    <dd><%= @newest_published_at&.strftime("%Y-%m-%d %H:%M UTC") %></dd>

    <dt>Total posts</dt>
    <dd><%= number_with_delimiter(@total) %></dd>
  </dl>

  <h2>Posts per type</h2>
  <p class="sub">Click a type to read posts past your reading lag (default 6 months).</p>
  <table>
    <thead>
      <tr><th>Type</th><th>Count</th></tr>
    </thead>
    <tbody>
      <% @counts_by_type.sort_by { |_type, count| -count }.each do |type, count| %>
        <tr>
          <td>
            <%= link_to PostsController::TYPE_LABELS.fetch(type, type.humanize),
                        posts_by_type_path(post_type: type) %>
          </td>
          <td><%= number_with_delimiter(count) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>
