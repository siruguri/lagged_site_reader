.max-w-2xl.mx-auto.py-8.px-4

  %h1.text-3xl.font-bold.mb-6 Submit Your Writing

  = form_with(model: @submission, local: true) do |form|
    .mb-6
      = form.label :title, class: "block text-sm font-medium mb-2"
      = form.text_field :title, placeholder: "Enter a title", class: "w-full px-3 py-2 border border-gray-300 rounded-md"

    .mb-6
      = form.label :content, class: "block text-sm font-medium mb-2"
      = form.text_area :content, rows: 15, placeholder: "Write your content here...", class: "w-full px-3 py-2 border border-gray-300 rounded-md font-mono text-sm"

    .flex.gap-4
      = form.submit "Submit", class: "px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700"
      = link_to "Cancel", root_path, class: "px-4 py-2 border border-gray-300 rounded-md hover:bg-gray-50"
