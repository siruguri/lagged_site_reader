# Copy to `.env` (chmod 600) and fill in. docker-compose reads it
# automatically.

# REQUIRED: contents of config/master.key from your Rails app. This decrypts
# config/credentials.yml.enc, where SECRET_KEY_BASE is stored. Without it the
# web container can't boot in production.
#
# Get it on your Mac with:
#   cat config/master.key
RAILS_MASTER_KEY=
